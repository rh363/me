---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SkillBadge from '../components/SkillBadge.astro';
import Footer from '../components/Footer.astro';

// ============================
// PERSONALIZZA I TUOI DATI QUI
// ============================

const info = {
  name: 'Alex',
  title: 'Full Stack Developer & Infrastructure Engineer',
  bio: 'Sviluppo applicazioni web e infrastrutture cloud, con passione per l\'architettura pulita, l\'automazione e i sistemi distribuiti.',
  github: 'https://github.com/rh363',
  linkedin: 'https://linkedin.com/in/alex-massaroni',
  email: 'alex.massaroni2004@gmail.com',
};

const projects = [
  {
    title: 'Cloud Image Management System',
    description: 'Sistema di gestione e storage immagini con task asincroni, backend distribuiti WebDAV, locking distribuito via Redis e architettura esagonale.',
    tech: ['Python', 'Django', 'Celery', 'Redis', 'Docker'],
  },
  {
    title: 'VPC Management Platform',
    description: 'Piattaforma full stack per la gestione di un servizio VPC (Virtual Private Cloud): frontend SPA reattivo per configurazione reti, subnet e risorse, con backend API per orchestrazione dell\'infrastruttura sottostante e pipeline CI/CD automatizzate.',
    tech: ['SvelteKit', 'TypeScript', 'Tailwind CSS', 'Django', 'Docker', 'GitLab CI/CD'],
  },
  {
    title: 'RPC Worker API',
    description: 'API worker in Go per operazioni su immagini disco (checksum, editing, cloning) con autenticazione JWT RS256 e orchestrazione tramite task queue.',
    tech: ['Go', 'JWT', 'Celery', 'Django'],
  },
  {
    title: 'Kubernetes & Infrastructure Stack',
    description: 'Setup e gestione cluster Kubernetes con Cilium, reverse proxy Traefik con plugin custom in Go, e monitoring Prometheus su Rocky Linux.',
    tech: ['Kubernetes', 'Traefik', 'Go', 'Prometheus', 'Rocky Linux'],
  },
  {
    title: 'Identity & Access Management',
    description: 'Integrazione Keycloak/OIDC across multiple services: SSO, token refresh, password reset flows, admin API wrapper.',
    tech: ['Keycloak', 'OIDC', 'Python', 'PHP'],
  },
];

const skills = [
  'Python', 'Django', 'Go', 'TypeScript', 'SvelteKit',
  'Flutter', 'Docker', 'Kubernetes', 'Traefik',
  'Linux (Rocky/Debian/Ubuntu)', 'Git', 'GitLab CI/CD',
  'Celery', 'Redis', 'PostgreSQL', 'MySQL',
  'Keycloak/OIDC', 'Nginx', 'Prometheus', 'KVM/libvirt',
  'HTML/CSS', 'Tailwind CSS', 'Hexagonal Architecture',
];
---

<BaseLayout>
  <Header />

  <main>
    <Hero
      name={info.name}
      title={info.title}
      bio={info.bio}
      github={info.github}
      linkedin={info.linkedin}
      email={info.email}
    />

    <!-- Chi Sono -->
    <section id="about">
      <div class="container">
        <h2 class="section-title">Chi Sono</h2>
        <div class="about-content fade-in">
          <p>
            Sono uno sviluppatore e infrastructure engineer con esperienza in ambienti cloud e hosting.
            Lavoro quotidianamente su backend in Python/Django e Go, frontend in SvelteKit e TypeScript,
            e gestisco infrastrutture basate su Docker, Kubernetes e Linux. Studio Ingegneria Informatica
            e Telecomunicazioni all'università, bilanciando lavoro e studio.
          </p>
          <p>
            Credo nell'architettura esagonale, nei principi SOLID e nelle soluzioni concrete.
            Quando non scrivo codice, esploro nuove tecnologie, dal mobile con Flutter
            all'orchestrazione con AI coding tools.
          </p>
        </div>
      </div>
    </section>

    <!-- Progetti -->
    <section id="projects" class="projects-section">
      <div class="container">
        <h2 class="section-title">Progetti</h2>
        <div class="projects-grid">
          {projects.map((project, i) => (
            <div class={`fade-in fade-in-delay-${(i % 4) + 1}`}>
              <ProjectCard {...project} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Competenze -->
    <section id="skills">
      <div class="container">
        <h2 class="section-title">Competenze</h2>
        <div class="skills-grid fade-in">
          {skills.map(skill => (
            <SkillBadge name={skill} />
          ))}
        </div>
      </div>
    </section>

    <!-- Contatti -->
    <section id="contact" class="contact-section">
      <div class="container contact-content">
        <h2 class="section-title">Contatti</h2>
        <p class="contact-text fade-in">
          Hai un progetto interessante o vuoi semplicemente fare due chiacchiere?
          Non esitare a contattarmi!
        </p>
        <a href={`mailto:${info.email}`} class="contact-btn fade-in fade-in-delay-1">
          Scrivimi &rarr;
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* About */
  .about-content {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .about-content p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }

  /* Projects */
  .projects-section {
    background: var(--color-bg-alt);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  /* Skills */
  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    max-width: 800px;
    margin: 0 auto;
  }

  /* Contact */
  .contact-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-text {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .contact-btn {
    display: inline-block;
    padding: 0.85rem 2.5rem;
    border-radius: var(--radius);
    background: var(--gradient-accent);
    color: white;
    font-weight: 600;
    font-size: 1rem;
    transition: all var(--transition);
  }

  .contact-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(139, 92, 246, 0.3);
    color: white;
  }
</style>
