---
import { techColors } from '../data/techColors';

interface Props {
  name: string;
}

const { name } = Astro.props;

const style = techColors[name];
---

<span
  class="badge"
  style={style ? `color: ${style.color}; background: ${style.bg}; border-color: ${style.border};` : ''}
>
  {name}
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.1rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text);
    transition: all var(--transition);
    cursor: default;
  }

  .badge:hover {
    transform: translateY(-2px);
    filter: brightness(1.2);
  }
</style>
