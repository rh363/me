---
interface Props {
  title: string;
  description: string;
  tech: string[];
  url?: string;
  github?: string;
}

const { title, description, tech, url, github } = Astro.props;

const techColors: Record<string, { color: string; bg: string }> = {
  'Python':       { color: '#3776AB', bg: 'rgba(55, 118, 171, 0.12)' },
  'Django':       { color: '#44B78B', bg: 'rgba(68, 183, 139, 0.12)' },
  'Go':           { color: '#00ADD8', bg: 'rgba(0, 173, 216, 0.12)' },
  'TypeScript':   { color: '#3178C6', bg: 'rgba(49, 120, 198, 0.12)' },
  'SvelteKit':    { color: '#FF3E00', bg: 'rgba(255, 62, 0, 0.12)' },
  'Docker':       { color: '#2496ED', bg: 'rgba(36, 150, 237, 0.12)' },
  'Kubernetes':   { color: '#326CE5', bg: 'rgba(50, 108, 229, 0.12)' },
  'Traefik':      { color: '#24A1C1', bg: 'rgba(36, 161, 193, 0.12)' },
  'Celery':       { color: '#37B24D', bg: 'rgba(55, 178, 77, 0.12)' },
  'Redis':        { color: '#DC382D', bg: 'rgba(220, 56, 45, 0.12)' },
  'Tailwind CSS': { color: '#06B6D4', bg: 'rgba(6, 182, 212, 0.12)' },
  'GitLab CI/CD': { color: '#FC6D26', bg: 'rgba(252, 109, 38, 0.12)' },
  'Keycloak':     { color: '#4D4D4D', bg: 'rgba(77, 77, 77, 0.12)' },
  'OIDC':         { color: '#4D4D4D', bg: 'rgba(77, 77, 77, 0.12)' },
  'Prometheus':   { color: '#E6522C', bg: 'rgba(230, 82, 44, 0.12)' },
  'Rocky Linux':  { color: '#10B981', bg: 'rgba(16, 185, 129, 0.12)' },
  'JWT':          { color: '#D63AFF', bg: 'rgba(214, 58, 255, 0.12)' },
  'PHP':          { color: '#777BB4', bg: 'rgba(119, 123, 180, 0.12)' },
};
---

<article class="card">
  <div class="card-header">
    <svg class="card-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h7l2 2h9a1 1 0 0 1 1 1v11a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"/></svg>
    <div class="card-links">
      {github && (
        <a href={github} target="_blank" rel="noopener noreferrer" aria-label="Codice sorgente">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
      )}
      {url && (
        <a href={url} target="_blank" rel="noopener noreferrer" aria-label="Demo live">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      )}
    </div>
  </div>
  <h3 class="card-title">{title}</h3>
  <p class="card-desc">{description}</p>
  <div class="card-tech">
    {tech.map(t => {
      const tc = techColors[t];
      return <span class="tech-tag" style={tc ? `color: ${tc.color}; background: ${tc.bg};` : ''}>{t}</span>;
    })}
  </div>
</article>

<style>
  .card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.75rem;
    transition: all var(--transition);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card:hover {
    transform: translateY(-5px);
    border-color: var(--color-accent);
    box-shadow: 0 10px 40px rgba(139, 92, 246, 0.1);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .card-icon {
    color: var(--color-accent);
  }

  .card-links {
    display: flex;
    gap: 0.75rem;
  }

  .card-links a {
    color: var(--color-text-muted);
    transition: color var(--transition);
  }

  .card-links a:hover {
    color: var(--color-accent);
  }

  .card-title {
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .card-desc {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    flex: 1;
    margin-bottom: 1.25rem;
  }

  .card-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tech-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent-alt);
    background: rgba(6, 182, 212, 0.1);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }
</style>
