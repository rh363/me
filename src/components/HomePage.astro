---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Hero from './Hero.astro';
import ProjectCard from './ProjectCard.astro';
import SkillBadge from './SkillBadge.astro';
import Footer from './Footer.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getProjects } from '../data/projects';
import { siteConfig } from '../data/siteConfig';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const info = {
  name: siteConfig.name,
  title: t('hero.title'),
  bio: t('hero.bio'),
  github: siteConfig.social.github,
  linkedin: siteConfig.social.linkedin,
  email: siteConfig.email,
};

const projects = getProjects(t);

const skillGroups = [
  { label: t('skills.languages'), skills: ['Python', 'Go', 'TypeScript', 'HTML/CSS'] },
  { label: t('skills.frameworks'), skills: ['Django', 'SvelteKit', 'Flutter', 'Tailwind CSS'] },
  { label: t('skills.infrastructure'), skills: ['Docker', 'Kubernetes', 'Traefik', 'Nginx', 'KVM/libvirt'] },
  { label: t('skills.devops'), skills: ['Git', 'GitLab CI/CD', 'Prometheus'] },
  { label: t('skills.data'), skills: ['PostgreSQL', 'MySQL', 'Redis', 'Celery'] },
  { label: t('skills.security'), skills: ['Keycloak/OIDC'] },
  { label: t('skills.os'), skills: ['Linux (Rocky/Debian/Ubuntu)'] },
  { label: t('skills.architecture'), skills: ['Hexagonal Architecture', 'SOLID Principles'] },
];
---

<BaseLayout lang={lang}>
  <Header />

  <main id="main-content">
    <Hero
      name={info.name}
      title={info.title}
      bio={info.bio}
      github={info.github}
      linkedin={info.linkedin}
      email={info.email}
    />

    <!-- About -->
    <section id="about">
      <div class="container">
        <h2 class="section-title">{t('about.title')}</h2>
        <div class="about-content fade-in">
          <p>{t('about.p1')}</p>
          <p>{t('about.p2')}</p>
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section id="projects" class="projects-section">
      <div class="container">
        <h2 class="section-title">{t('projects.title')}</h2>
        <div class="projects-grid">
          {projects.map((project, i) => (
            <div class={`fade-in fade-in-delay-${(i % 4) + 1}`}>
              <ProjectCard {...project} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section id="skills">
      <div class="container">
        <h2 class="section-title">{t('skills.title')}</h2>
        <div class="skill-groups fade-in">
          {skillGroups.map(group => (
            <div class="skill-group">
              <h3 class="skill-group-label">{group.label}</h3>
              <div class="skills-grid">
                {group.skills.map(skill => (
                  <SkillBadge name={skill} />
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="contact-section">
      <div class="container contact-content">
        <h2 class="section-title">{t('contact.title')}</h2>
        <p class="contact-text fade-in">{t('contact.text')}</p>
        <a href={`mailto:${info.email}`} class="contact-btn fade-in fade-in-delay-1">
          {t('contact.cta')} &rarr;
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* About */
  .about-content {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .about-content p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }

  /* Projects */
  .projects-section {
    background: var(--color-bg-alt);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 900px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Skills */
  .skill-groups {
    max-width: 800px;
    margin: 0 auto;
  }

  .skill-group {
    margin-bottom: 1.75rem;
  }

  .skill-group:last-child {
    margin-bottom: 0;
  }

  .skill-group-label {
    text-align: center;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  /* Contact */
  .contact-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-text {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .contact-btn {
    display: inline-block;
    padding: 0.85rem 2.5rem;
    border-radius: var(--radius);
    background: var(--gradient-accent);
    color: white;
    font-weight: 600;
    font-size: 1rem;
    transition: all var(--transition);
  }

  .contact-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(139, 92, 246, 0.3);
    color: white;
  }
</style>
