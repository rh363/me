---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-content">
    <p class="footer-text">
      &copy; {year} Alex
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    text-align: center;
  }

  .footer-text {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .footer-text a {
    color: var(--color-accent);
    font-weight: 500;
  }
</style>
